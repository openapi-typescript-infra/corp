{
  "name": "@justtellme/run-local",
  "version": "0.0.0",
  "description": "Service runner for Just Tell Me development",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "bin": "src/bin/run-local.ts",
  "scripts": {
    "build": "yarn -T run build-package",
    "typecheck": "tsgo -p tsconfig.json",
    "clean": "yarn dlx rimraf ./build",
    "lint": "biome check src",
    "start": "tsx src/bin/run-local.ts"
  },
  "engines": {
    "node": ">24.0.0"
  },
  "author": "Just Tell Me Developers <developers@justtellme.com>",
  "config": {
    "cpconfig": "@justtellme/cpconfig"
  },
  "keywords": [
    "typescript",
    "development"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@justtellme/cpconfig": "workspace:^",
    "@types/figlet": "^1.7.0",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260418.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "figlet": "^1.11.0",
    "ink": "^7.0.5",
    "minimist": "^1.2.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "packageManager": "yarn@3.8.7"
}
