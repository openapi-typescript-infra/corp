{
  "//": "Managed by cpconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "noEmitOnError": false,
    "outDir": "dist/",
    "incremental": false,
    "rewriteRelativeImportExtensions": true,
    "types": ["node"],
    "paths": {
      "#src/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.spec.*",
    "src/**/*.test.*",
    "src/**/*.stories.*",
    "src/**/*.chromatic.*",
    "src/**/*.fixtures.*",
    "src/codegen",
    "src/.storybook"
  ]
}
