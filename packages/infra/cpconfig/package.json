{
  "name": "@justtellme/cpconfig",
  "version": "0.0.0",
  "description": "Standard Typescript/Node/React configuration for Just Tell Me projects",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "type": "module",
  "types": "./src/index.ts",
  "author": "Developers <developers@justtellme.com>",
  "license": "UNLICENSED",
  "packageManager": "yarn@3.8.7",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "postinstall": "cpconfig",
    "test": "vitest"
  },
  "keywords": [
    "typescript",
    "justtellme"
  ],
  "config": {
    "cpconfig": "./src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260404.1",
    "cpconfig": "^1.5.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
