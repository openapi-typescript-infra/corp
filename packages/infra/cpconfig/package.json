{
  "name": "@justtellme/cpconfig",
  "version": "0.0.0",
  "description": "Standard Typescript/Node/React configuration for Just Tell Me projects",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./ts-extension-replacer.cjs": "./ts-extension-replacer.cjs"
  },
  "bin": {
    "build-package": "bin/build-package.ts"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "templates",
    "ts-extension-replacer.cjs"
  ],
  "type": "module",
  "types": "./src/index.ts",
  "author": "Developers <developers@justtellme.com>",
  "license": "UNLICENSED",
  "packageManager": "yarn@3.8.7",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "build": "yarn -T run build-package",
    "lint": "biome check .",
    "test": "vitest"
  },
  "keywords": [
    "typescript",
    "justtellme"
  ],
  "config": {
    "cpconfig": "./src/index.ts"
  },
  "dependencies": {
    "tsc-alias": "^1.8.17"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.2",
    "@typescript/native-preview": "^7.0.0-dev.20260418.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
