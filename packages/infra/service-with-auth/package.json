{
  "name": "@justtellme/service-with-auth",
  "version": "0.0.0",
  "description": "Base module for Just Tell Me Typescript applications with authentication",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "test": "vitest",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "clean": "yarn dlx rimraf ./build",
    "lint": "eslint src",
    "postinstall": "cpconfig",
    "start": "yarn start-service --rootDirectory __tests__/justtellme-api --codepath src --packageDir __tests__/justtellme-api"
  },
  "engines": {
    "node": ">24.0.0"
  },
  "files": [
    "src",
    "config",
    "README.md"
  ],
  "author": "Just Tell Me Developers <developers@justtellme.com>",
  "config": {
    "cpconfig": "@justtellme/cpconfig"
  },
  "keywords": [
    "typescript",
    "justtellme"
  ],
  "devDependencies": {
    "@openapi-typescript-infra/service-tester": "^7.1.2",
    "@types/express-session": "^1.18.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@justtellme/api": "workspace:^",
    "@justtellme/cpconfig": "workspace:^",
    "@justtellme/service": "workspace:^",
    "@justtellme/web-auth": "workspace:^",
    "@openapi-typescript-infra/service": "^6.13.1",
    "cpconfig": "^1.5.0",
    "lodash": "^4.18.1"
  },
  "packageManager": "yarn@3.8.7"
}
