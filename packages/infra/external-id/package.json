{
  "name": "@justtellme/external-id",
  "version": "0.0.0",
  "description": "Formatted, shortened, scoped UUIDs",
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "author": "Developers <developers@justtellme.com>",
  "license": "UNLICENSED",
  "bin": "src/cli.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "postinstall": "cpconfig",
    "test": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "typescript",
    "justtellme"
  ],
  "config": {
    "cpconfig": "@justtellme/cpconfig"
  },
  "devDependencies": {
    "@justtellme/cpconfig": "workspace:^",
    "@types/any-base": "^1.1.3",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260404.1",
    "cpconfig": "^1.5.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "any-base": "^1.1.0"
  }
}
