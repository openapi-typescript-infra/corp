{
  "name": "@justtellme/external-id",
  "version": "0.0.0",
  "description": "Formatted, shortened, scoped UUIDs",
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "author": "Developers <developers@justtellme.com>",
  "license": "UNLICENSED",
  "bin": "src/cli.ts",
  "scripts": {
    "build": "yarn -T run build-package",
    "lint": "biome check .",
    "test": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "typescript",
    "justtellme"
  ],
  "config": {
    "cpconfig": "@justtellme/cpconfig"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@justtellme/cpconfig": "workspace:^",
    "@types/node": "^25.9.0",
    "@typescript/native-preview": "^7.0.0-dev.20260418.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@openapi-typescript-infra/external-id": "^1.2.0"
  }
