{
  "name": "@justtellme/service-tester",
  "version": "0.0.0",
  "description": "Utilities to make testing Just Tell Me Typescript services easier and less repetitive",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "type": "module",
  "files": [
    "src"
  ],
  "author": "Developers <developers@justtellme.com>",
  "license": "UNLICENSED",
  "packageManager": "yarn@3.8.7",
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "postinstall": "cpconfig",
    "test": "vitest"
  },
  "keywords": [
    "typescript",
    "justtellme"
  ],
  "config": {
    "cpconfig": "@justtellme/cpconfig"
  },
  "devDependencies": {
    "@justtellme/cpconfig": "workspace:^",
    "@types/jwt-encode": "^1.0.3",
    "@types/node": "^25.5.0",
    "cpconfig": "^1.4.4",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "vitest": ">=1.3.1"
  },
  "dependencies": {
    "@justtellme/service": "workspace:^",
    "@justtellme/web-auth": "workspace:^",
    "@openapi-typescript-infra/service-tester": "^7.1.2",
    "@types/express-session": "^1.18.2",
    "jwt-encode": "^1.0.1",
    "msw": "^2.12.10",
    "node-mocks-http": "^1.17.2"
  }
}
