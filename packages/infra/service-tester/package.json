{
  "name": "@justtellme/service-tester",
  "version": "0.0.0",
  "description": "Utilities to make testing Just Tell Me Typescript services easier and less repetitive",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "type": "module",
  "files": [
    "src"
  ],
  "author": "Developers <developers@justtellme.com>",
  "license": "UNLICENSED",
  "packageManager": "yarn@3.8.7",
  "scripts": {
    "build": "yarn -T run build-package",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "biome check .",
    "test": "vitest"
  },
  "keywords": [
    "typescript",
    "justtellme"
  ],
  "config": {
    "cpconfig": "@justtellme/cpconfig"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@justtellme/cpconfig": "workspace:^",
    "@types/jwt-encode": "^1.0.3",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260418.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "vitest": ">=1.3.1"
  },
  "dependencies": {
    "@justtellme/service": "workspace:^",
    "@justtellme/web-auth": "workspace:^",
    "@openapi-typescript-infra/service-tester": "^7.1.2",
    "@types/express-session": "^1.19.0",
    "jwt-encode": "^1.0.1",
    "msw": "^2.14.6",
    "node-mocks-http": "^1.17.2"
  }
}
