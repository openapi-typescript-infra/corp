{
  "name": "@justtellme/state",
  "version": "0.0.0",
  "description": "Just Tell Me UI state management",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "types": "./src/index.ts",
  "author": "Max Metral <max@pyralis.com>",
  "license": "UNLICENSED",
  "packageManager": "yarn@3.8.7",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "build": "yarn -T run build-package",
    "clean": "yarn dlx rimraf ./dist",
    "lint": "biome check .",
    "test": "vitest"
  },
  "keywords": [
    "typescript",
    "justtellme"
  ],
  "config": {
    "cpconfig": "@justtellme/cpconfig"
  },
  "dependencies": {
    "@legendapp/state": "^3.0.0-beta.46"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@justtellme/cpconfig": "workspace:^",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
