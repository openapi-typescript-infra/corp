{
  "name": "@justtellme/web-auth",
  "version": "0.0.0",
  "description": "Just Tell Me authentication and session management",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "author": "Developers <developers@justtellme.com>",
  "license": "UNLICENSED",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "build": "yarn -T run build-package",
    "lint": "biome check .",
    "test": "vitest",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "keywords": [
    "typescript",
    "justtellme",
    "authentication",
    "authorization",
    "middleware"
  ],
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "config": {
    "cpconfig": "@justtellme/cpconfig"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@justtellme/service": "workspace:^",
    "@openapi-typescript-infra/service": "^6.14.1",
    "@openapi-typescript-infra/service-tester": "^7.1.2",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.0",
    "@typescript/native-preview": "^7.0.0-dev.20260418.1",
    "nock": "^14.0.15",
    "node-mocks-http": "^1.17.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@openapi-typescript-infra/service": ">=6.0.0"
  },
  "dependencies": {
    "@justtellme/api": "workspace:^",
    "@justtellme/auth-token": "workspace:^",
    "@justtellme/cpconfig": "workspace:^",
    "@justtellme/external-id": "workspace:^",
    "@sesamecare-oss/async-rule-evaluator": "^1.2.0",
    "@types/jsonwebtoken": "^9.0.10",
    "connect-redis": "^9.0.0",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "redis": "^5.12.1",
    "stytch": "^13.2.3",
    "vitest-fetch-mock": "^0.4.5"
  }
}
