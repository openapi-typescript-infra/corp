{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "generate"],
      "outputs": ["dist/**", ".next/**", "private/**"],
      "passThroughEnv": ["PGPORT", "PGHOST", "PGUSER", "PGPASSWORD", "PGDATABASE"]
    },
    "clean": {
      "cache": false
    },
    "cpconfig": {
      "cache": false
    },
    "generate": {
      "outputs": ["src/generated/**"],
      "passThroughEnv": ["PGPORT", "PGHOST", "PGUSER", "PGPASSWORD", "PGDATABASE"]
    },
    "test": {
      "dependsOn": ["^build"],
      "passThroughEnv": ["PGPORT", "PGHOST", "PGUSER", "PGPASSWORD", "PGDATABASE"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "build:next": {
      "dependsOn": ["^build"],
      "outputs": ["private/**", ".next/**", "__tests__/sample-web/private/**", "__tests__/sample-web/.next/**"],
      "env": ["NODE_ENV", "APP_ENV"],
      "passThroughEnv": ["GITHUB_SHA", "NO_SENTRY_UPLOAD", "SENTRY_AUTH_TOKEN"]
    },
    "check-bundles": {
      "dependsOn": ["build:next"]
    }
  }
}
