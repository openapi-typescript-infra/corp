{
  "name": "@justtellme/payment-internal",
  "private": true,
  "version": "0.0.0",
  "description": "Payment ledger and APIs",
  "main": "./src/index.ts",
  "exports": "./src/index.ts",
  "type": "module",
  "types": "src/index.ts",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "test": "vitest",
    "build": "make",
    "watch": "nodemon",
    "clean": "make clean",
    "start": "start-service",
    "repl": "start-service --repl",
    "ci-setup": "make db-ci",
    "db:create": "yarn dlx -q run-pg-sql postgres ./migrations/setup/db_setup.sql",
    "migration:apply": "db-migrate --config migrations/db-migrate.json up",
    "migration:undo": "db-migrate --config migrations/db-migrate.json down",
    "migration:create": "db-migrate --config migrations/db-migrate.json create",
    "lint": "biome check ."
  },
  "config": {
    "cpconfig": "@justtellme/cpconfig"
  },
  "engines": {
    "node": ">24.0.0"
  },
  "author": "Max Metral <max@pyralis.com>",
  "license": "UNLICENSED",
  "keywords": [
    "typescript",
    "openapi",
    "express"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@openapi-typescript-infra/service-tester": "^7.1.2",
    "@typescript/native-preview": "^7.0.0-dev.20260418.1",
    "kysely-codegen": "^0.20.0",
    "run-pg-sql": "^1.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@justtellme/cpconfig": "workspace:^",
    "@justtellme/external-id": "workspace:^",
    "@justtellme/service": "workspace:^",
    "@openapi-typescript-infra/service": "^6.13.1",
    "date-fns": "^4.1.0",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "kysely": "^0.28.15",
    "pg": "^8.20.0"
  }
}
